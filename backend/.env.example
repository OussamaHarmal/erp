# Sage export folder (optional)
# Use a Windows/shared folder when backend runs on Windows or has access to the shared path.
# Example Windows: SAGE_EXPORT_DROP_DIR=C:\\SAGE_IMPORT\\VENTES
# Example Docker bind mount: SAGE_EXPORT_DROP_DIR=/app/exports/sage
SAGE_EXPORT_DROP_DIR=exports/sage
SAGE_JOURNAL_CODE=VTE
SAGE_CLIENT_ACCOUNT=34210000
SAGE_SALES_ACCOUNT=71243000
SAGE_VAT_ACCOUNT=44550000
SAGE_DEFAULT_TIERS_CODE=B01


# AI Chatbot - OpenAI compatible API
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_CHATBOT_ENABLED=true

# Sage Auto Import intégré au backend - Windows seulement
SAGE_AUTO_IMPORT_ENABLED=false
SAGE_AUTO_IMPORT_FOLDER=C:\SAGE_AUTO_IMPORT\pending
SAGE_IMPORTED_FOLDER=C:\SAGE_AUTO_IMPORT\imported
SAGE_ERROR_FOLDER=C:\SAGE_AUTO_IMPORT\errors
SAGE_IMPORT_LOG_FILE=C:\SAGE_AUTO_IMPORT\logs\import.log
SAGE_EXE_PATH=C:\Program Files (x86)\Sage\iComptabilité\Maestria.exe
